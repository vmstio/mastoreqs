---
// A customised copy of Starlight's `SidebarSublist` (v0.36.x). The only
// behavioural change: when an autogenerated group contains an index/overview
// page (a child whose URL is a path-prefix of its siblings), the group's
// heading text becomes a link to that page and the separate "Overview" child is
// dropped. Everything else mirrors the upstream component so the rest of the
// sidebar — badges, carets, collapse state, scroll restoration — is unchanged.
import { Icon, Badge } from '@astrojs/starlight/components';

interface SidebarLink {
  type: 'link';
  label: string;
  href: string;
  isCurrent: boolean;
  badge: { variant?: string; class?: string; text: string } | undefined;
  attrs: Record<string, unknown>;
}
interface SidebarGroup {
  type: 'group';
  label: string;
  entries: SidebarEntry[];
  collapsed: boolean;
  badge: { variant?: string; class?: string; text: string } | undefined;
}
type SidebarEntry = SidebarLink | SidebarGroup;

interface Props {
  sublist: SidebarEntry[];
  nested?: boolean;
}

const { sublist, nested } = Astro.props;

/** First link href found anywhere beneath an entry, used for prefix matching. */
function firstHref(entry: SidebarEntry): string | undefined {
  if (entry.type === 'link') return entry.href;
  for (const child of entry.entries) {
    const href = firstHref(child);
    if (href) return href;
  }
  return undefined;
}

/**
 * The index/overview page of a group: a direct child link whose href is a path
 * prefix of at least one sibling (e.g. `/components/cache/` under the vendor
 * pages). Returns `undefined` for groups without such a landing page.
 */
function getOverview(group: SidebarGroup): SidebarLink | undefined {
  return group.entries.find(
    (entry): entry is SidebarLink =>
      entry.type === 'link' &&
      // Ignore the site root (`/`), which is trivially a prefix of everything;
      // only a real subdirectory index (e.g. `/components/cache/`) should hoist.
      entry.href.split('/').filter(Boolean).length >= 1 &&
      group.entries.some((other) => other !== entry && firstHref(other)?.startsWith(entry.href))
  );
}

/** Whether any entry below `entries` is the current page (controls open state). */
function containsCurrent(entries: SidebarEntry[]): boolean {
  return entries.some((entry) =>
    entry.type === 'group' ? containsCurrent(entry.entries) : entry.isCurrent
  );
}

/** Running index for `<sl-sidebar-restore>`, matching upstream's SidebarRestorePoint. */
const groupIndexSymbol = Symbol.for('starlight-sidebar-group-index');
const locals = Astro.locals as Record<symbol, number>;
function nextRestoreIndex(): number {
  const index = locals[groupIndexSymbol] || 0;
  locals[groupIndexSymbol] = index + 1;
  return index;
}
---

<ul class:list={{ 'top-level': !nested }}>
  {
    sublist.map((entry) => (
      <li>
        {entry.type === 'link' ? (
          <a
            href={entry.href}
            aria-current={entry.isCurrent && 'page'}
            class:list={[{ large: !nested }, entry.attrs.class]}
            {...entry.attrs}
          >
            <span>{entry.label}</span>
            {entry.badge && (
              <Badge variant={entry.badge.variant} class={entry.badge.class} text={entry.badge.text} />
            )}
          </a>
        ) : (
          (() => {
            const overview = getOverview(entry);
            const children = overview ? entry.entries.filter((e) => e !== overview) : entry.entries;
            const open = containsCurrent(entry.entries) || !entry.collapsed;
            return (
              <details open={open}>
                <summary>
                  <span class="group-label">
                    {overview ? (
                      <a
                        class="group-label-link"
                        href={overview.href}
                        aria-current={overview.isCurrent && 'page'}
                      >
                        <span class="large">{entry.label}</span>
                      </a>
                    ) : (
                      <span class="large">{entry.label}</span>
                    )}
                    {entry.badge && (
                      <Badge variant={entry.badge.variant} class={entry.badge.class} text={entry.badge.text} />
                    )}
                  </span>
                  <Icon name="right-caret" class="caret" size="1.25rem" />
                </summary>
                <sl-sidebar-restore data-index={nextRestoreIndex()} />
                <Astro.self sublist={children} nested />
              </details>
            );
          })()
        )}
      </li>
    ))
  }
</ul>

<style>
  @layer starlight.core {
    ul {
      --sl-sidebar-item-padding-inline: 0.5rem;
      list-style: none;
      padding: 0;
    }

    li {
      overflow-wrap: anywhere;
    }

    ul ul li {
      margin-inline-start: var(--sl-sidebar-item-padding-inline);
      border-inline-start: 1px solid var(--sl-color-hairline-light);
      padding-inline-start: var(--sl-sidebar-item-padding-inline);
    }

    .large {
      font-size: var(--sl-text-lg);
      font-weight: 600;
      color: var(--sl-color-white);
    }

    .top-level > li + li {
      margin-top: 0.75rem;
    }

    summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.2em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
      cursor: pointer;
      user-select: none;
    }
    summary::marker,
    summary::-webkit-details-marker {
      display: none;
    }

    .caret {
      transition: transform 0.2s ease-in-out;
      flex-shrink: 0;
    }
    :global([dir='rtl']) .caret {
      transform: rotateZ(180deg);
    }
    [open] > summary .caret {
      transform: rotateZ(90deg);
    }

    a {
      display: block;
      border-radius: 0.25rem;
      text-decoration: none;
      color: var(--sl-color-gray-2);
      padding: 0.3em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
    }

    a:hover,
    a:focus {
      color: var(--sl-color-white);
    }

    [aria-current='page'],
    [aria-current='page']:hover,
    [aria-current='page']:focus {
      font-weight: 600;
      color: var(--sl-color-text-invert);
      background-color: var(--sl-color-text-accent);
    }

    a > *:not(:last-child),
    .group-label > *:not(:last-child) {
      margin-inline-end: 0.25em;
    }

    /* The group heading-as-link sits inline inside the summary and inherits the
       `.large` styling, so it should not pick up the block/padding treatment of
       child links. Active state is a subtle accent tint rather than a full pill,
       which would look oversized on the bold heading. */
    .group-label-link {
      display: inline;
      padding: 0;
      color: inherit;
    }
    .group-label-link:hover,
    .group-label-link:focus,
    .group-label-link:hover .large,
    .group-label-link:focus .large {
      color: var(--sl-color-text-accent);
    }
    .group-label-link[aria-current='page'] {
      background: none;
      font-weight: inherit;
    }
    .group-label-link[aria-current='page'] .large {
      color: var(--sl-color-text-accent);
    }

    @media (min-width: 50rem) {
      .top-level > li + li {
        margin-top: 0.5rem;
      }
      .large {
        font-size: var(--sl-text-base);
      }
      a {
        font-size: var(--sl-text-sm);
      }
    }
  }
</style>

<script>
  // A group heading is an `<a>` nested inside the `<summary>`, so a native
  // browser click would both follow the link *and* toggle the parent
  // `<details>` (which SidebarPersister then remembers, leaving the group
  // collapsed after navigation). Stopping propagation keeps the click from
  // reaching the summary's toggle handler while the link still navigates, so
  // expanding/collapsing remains the caret's job.
  function wireGroupLabelLinks() {
    document.querySelectorAll<HTMLAnchorElement>('a.group-label-link').forEach((link) => {
      if (link.dataset.noToggleWired) return;
      link.dataset.noToggleWired = 'true';
      link.addEventListener('click', (event) => event.stopPropagation());
    });
  }

  wireGroupLabelLinks();
  // Re-wire after view-transition navigations, if enabled.
  document.addEventListener('astro:page-load', wireGroupLabelLinks);
</script>
