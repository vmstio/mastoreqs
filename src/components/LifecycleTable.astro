---
import { lifecycle, type LifecycleState } from '../data/requirements';

const stateMeta: Record<LifecycleState, { symbol: string; label: string }> = {
  development: { symbol: '✓', label: 'Development Branch' },
  supported: { symbol: '✓', label: 'Release Branch' },
  eol: { symbol: '✕', label: 'End of Life' },
};
---

<figure class="support-matrix lifecycle-table">
  <div class="sm-scroll">
    <table>
      <thead>
        <tr>
          <th scope="col"></th>
          <th scope="col">Branch Status</th>
          <th scope="col">End of Life Date</th>
          <th scope="col" class="sm-center"><span class="sr-only">Supported</span></th>
        </tr>
      </thead>
      <tbody>
        {
          lifecycle.map((entry) => (
            <tr data-state={entry.state}>
              <th scope="row" class="sm-row-head">{entry.version}</th>
              <td>{entry.status}</td>
              <td>{entry.endOfLife ?? '—'}</td>
              <td class="sm-cell sm-center" data-state={entry.state}>
                <span class="sm-mark" role="img" aria-label={stateMeta[entry.state].label}>
                  {stateMeta[entry.state].symbol}
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="sm-legend">
    <span class="sm-legend-item" data-state="supported">
      <span class="sm-mark">✓</span> Supported
    </span>
    <span class="sm-legend-item" data-state="warn">
      <span class="sm-mark">!</span> Deprecated
    </span>
    <span class="sm-legend-item" data-state="eol">
      <span class="sm-mark">✕</span> End of Life
    </span>
  </div>
</figure>
