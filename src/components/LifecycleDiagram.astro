---
import { lifecycle, branchName, type LifecycleState } from '../data/requirements';

/**
 * Branch lifecycle diagram, generated from the same `lifecycle` data that drives
 * LifecycleTable. It replaces the former hand-drawn `mastodon-branches.png`: a
 * git-graph of every tracked branch diverging from `main`, coloured by state.
 *
 * Geometry is computed here so the SVG always reflects the JSON — adding or
 * retiring a branch reshapes the diagram with no markup to touch.
 */

// Layout constants (user units; the <svg> scales to fit its container).
const COL_W = 92; // horizontal spacing between branch columns
const MAIN_GAP = 185; // wider gap before `main`, giving the nightly dots room
const PAD_LEFT = 80; // room left of the first branch (and the logo)
const PAD_RIGHT = 70; // room right of `main` for the timeline arrowhead
const TIMELINE_Y = 252;
const KINK_Y = 190; // where a branch line bends from diagonal to vertical
const NODE_Y = 124; // centre of a branch's node square
const NODE_DX = 22; // node sits this far right of its branch point
const NODE = 14; // node square side
const TICK = 11; // branch-point square side

const STATE_COLOR: Record<LifecycleState, string> = {
  eol: 'var(--lc-eol)',
  deprecated: 'var(--lc-deprecated)',
  supported: 'var(--lc-supported)',
  development: 'var(--lc-dev)',
};

/** "4.5" -> "4.5.x"; anything already wild (e.g. "3.x") is left alone. */
const versionLabel = (v: string) => (/x/i.test(v) ? v : `${v}.x`);

// `lifecycle` is newest-first; the timeline reads oldest-left -> newest-right,
// with the single development branch pinned to the far right as `main`.
const dev = lifecycle.find((e) => e.state === 'development');
const branches = lifecycle
  .filter((e) => e.state !== 'development')
  .slice()
  .reverse()
  .map((entry, i) => {
    const tickX = PAD_LEFT + i * COL_W;
    return {
      ...entry,
      tickX,
      nodeX: tickX + NODE_DX,
      color: STATE_COLOR[entry.state],
      // Sub-label captioning the node: a supported branch shows its status'
      // first word ("Latest"/"Previous"), a deprecated branch shows
      // "Deprecated"; EOL branches have none.
      subLabel:
        entry.state === 'supported'
          ? entry.status.split(' ')[0]
          : entry.state === 'deprecated'
            ? 'Deprecated'
            : null,
    };
  });

const lastBranchX = PAD_LEFT + (branches.length - 1) * COL_W;
const mainX = lastBranchX + MAIN_GAP;
const width = mainX + PAD_RIGHT;
const HEIGHT = 304;

// Branches group into captioned bands across the top. A deprecated branch still
// receives backported fixes, so it shares the "Supported" band — only its
// yellow colour and "Deprecated" sub-label set it apart. The band header colour
// follows the band, not the individual branch.
const BAND: Partial<Record<LifecycleState, { id: string; title: string; color: string }>> = {
  eol: { id: 'eol', title: 'End of Life', color: 'var(--lc-eol)' },
  deprecated: { id: 'supported', title: 'Supported / Backported Fixes', color: 'var(--lc-supported)' },
  supported: { id: 'supported', title: 'Supported / Backported Fixes', color: 'var(--lc-supported)' },
};
type Cluster = { centerX: number; title: string; color: string };
const bands: { id: string; title: string; color: string; xs: number[] }[] = [];
for (const b of branches) {
  const band = BAND[b.state];
  if (!band) continue;
  const last = bands[bands.length - 1];
  if (last && last.id === band.id) last.xs.push(b.nodeX);
  else bands.push({ id: band.id, title: band.title, color: band.color, xs: [b.nodeX] });
}
const clusters: Cluster[] = bands.map((band) => ({
  title: band.title,
  color: band.color,
  centerX: (band.xs[0] + band.xs[band.xs.length - 1]) / 2,
}));

// Nightly dots ride the timeline, centred in the gap before `main`.
const dotsMid = (lastBranchX + mainX) / 2;
const dots = [dotsMid - 24, dotsMid, dotsMid + 24];
const supported = branches.filter((b) => b.state === 'supported');
// The backport arrow lands on the newest supported branch (its rightmost node).
const supEndX = supported.length ? supported[supported.length - 1].nodeX : mainX - COL_W;
---

<figure class="lifecycle-diagram not-content">
  <svg
    viewBox={`0 0 ${width} ${HEIGHT}`}
    role="img"
    aria-labelledby="lc-diagram-title lc-diagram-desc"
    preserveAspectRatio="xMidYMid meet"
  >
    <title id="lc-diagram-title">Mastodon branch lifecycle</title>
    <desc id="lc-diagram-desc">
      A git-graph of the tracked Mastodon branches diverging from the main development
      branch: {branches.map((b) => `${branchName(b)} (${b.status})`).join(', ')}.
    </desc>

    <defs>
      <marker
        id="lc-arrow-line"
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="var(--lc-line)" />
      </marker>
      <marker
        id="lc-arrow-back"
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="var(--lc-supported)" />
      </marker>
    </defs>

    {/* Mastodon mark, top-left, mirroring the original graphic. */}
    <g transform="translate(16,14) scale(0.17)" aria-hidden="true">
      <path
        fill="#6364ff"
        d="M211.80734 139.0875c-3.18125 16.36625-28.4925 34.2775-57.5625 37.74875-15.15875 1.80875-30.08375 3.47125-45.99875 2.74125-26.0275-1.1925-46.565-6.2125-46.565-6.2125 0 2.53375.15625 4.94625.46875 7.2025 3.38375 25.68625 25.47 27.225 46.39125 27.9425 21.11625.7225 39.91875-5.20625 39.91875-5.20625l.8675 19.09s-14.77 7.93125-41.08125 9.39c-14.50875.7975-32.52375-.365-53.50625-5.91875C9.23234 213.82 1.40609 165.31125.20859 116.09125c-.365-14.61375-.14-28.39375-.14-39.91875 0-50.33 32.97625-65.0825 32.97625-65.0825C49.78484 3.34875 78.20109.46625 107.74859.225h.725c29.545.24125 57.97875 3.12375 74.71125 10.86625 0 0 32.975 14.7525 32.975 65.0825 0 0 .41375 37.13375-4.59875 62.9125"
      />
      <path
        fill="#fff"
        d="M177.50984 80.077v60.94125h-24.14375v-59.15c0-12.46875-5.24625-18.7975-15.74-18.7975-11.6025 0-17.4175 7.5075-17.4175 22.3525v32.37625H96.20734V85.42325c0-14.845-5.81625-22.3525-17.41875-22.3525-10.49375 0-15.74 6.32875-15.74 18.7975v59.15H38.90484V80.077c0-12.455 3.17125-22.3525 9.54125-29.675 6.56875-7.3225 15.17125-11.07625 25.85-11.07625 12.355 0 21.71125 4.74875 27.8975 14.2475l6.01375 10.08125 6.015-10.08125c6.185-9.49875 15.54125-14.2475 27.8975-14.2475 10.6775 0 19.28 3.75375 25.85 11.07625 6.36875 7.3225 9.54 17.22 9.54 29.675"
      />
    </g>

    {/* Main timeline. */}
    <line
      class="lc-timeline"
      x1="40"
      y1={TIMELINE_Y}
      x2={mainX}
      y2={TIMELINE_Y}
      marker-end="url(#lc-arrow-line)"
    />

    {/* Backported-fixes arrow: main flows back to the newest supported branch,
        arcing across the top so it clears the cluster headers below. */}
    {supported.length > 0 && (
      <path
        class="lc-backport"
        d={`M ${mainX},32 C ${mainX},10 ${supEndX + 45},10 ${supEndX},22`}
        marker-end="url(#lc-arrow-back)"
      />
    )}

    {/* Band headers, centred over the branches they caption. */}
    {clusters.map((c) => (
      <text class="lc-cluster" x={c.centerX} y="60" style={`fill:${c.color}`}>
        {c.title}
      </text>
    ))}

    {/* Branches. */}
    {branches.map((b) => (
      <g>
        <path
          class="lc-branch"
          d={`M ${b.tickX},${TIMELINE_Y} L ${b.nodeX},${KINK_Y} L ${b.nodeX},${NODE_Y + NODE / 2}`}
          style={`stroke:${b.color}`}
        />
        <rect
          x={b.tickX - TICK / 2}
          y={TIMELINE_Y - TICK / 2}
          width={TICK}
          height={TICK}
          style={`fill:${b.color}`}
        />
        <rect
          x={b.nodeX - NODE / 2}
          y={NODE_Y - NODE / 2}
          width={NODE}
          height={NODE}
          rx="1.5"
          style={`fill:${b.color}`}
        />
        {b.subLabel && (
          <text class="lc-sublabel" x={b.nodeX} y={NODE_Y - 44} style={`fill:${b.color}`}>
            {b.subLabel}
          </text>
        )}
        <text class="lc-version" x={b.nodeX} y={NODE_Y - 22} style={`fill:${b.color}`}>
          {versionLabel(b.version)}
        </text>
        <text class="lc-branchname" x={b.tickX} y={TIMELINE_Y + 26} style={`fill:${b.color}`}>
          {branchName(b)}
        </text>
      </g>
    ))}

    {/* Development branch: nightly/alpha dots feeding into `main`. */}
    {dev && (
      <g>
        {dots.map((cx) => (
          <circle cx={cx} cy={TIMELINE_Y} r="5.5" style={`fill:${STATE_COLOR.development}`} />
        ))}
        <text
          class="lc-nightly"
          x={dots[1]}
          y={TIMELINE_Y - 22}
          style={`fill:${STATE_COLOR.development}`}
        >
          {dev.version} Nightly
        </text>
      </g>
    )}
    <text class="lc-branchname" x={mainX} y={TIMELINE_Y + 26} style={`fill:var(--lc-dev)`}>
      main
    </text>
  </svg>
</figure>
